# Cerebras API key (required)
CEREBRAS_API_KEY="csk-..."

# Gemini API key (for the live "GPU vs Cerebras" speed race).
# Apples-to-apples: the race runs the SAME model (Gemma 4 31B) on both sides -
# gemma-4-31b on Cerebras vs gemma-4-31b-it on Google's Gemini API (GPU).
GEMINI_API_KEY="AIza..."

# Optional overrides for the race (sensible defaults are used otherwise):
# CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
# RACE_CEREBRAS_MODEL="gemma-4-31b"
# RACE_GEMINI_MODEL="gemma-4-31b-it"
# RACE_MAX_TOKENS="700"

# Optional: generic GPU baseline for the CLI latency benchmark (src/bench.py).
# BASELINE_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
# BASELINE_API_KEY="AIza..."
# BASELINE_MODEL="gemma-4-31b-it"
